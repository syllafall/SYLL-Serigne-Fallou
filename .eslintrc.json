{
    "env": {
      "browser": true,
      "es2021": true,
      "node": true,
      "jest": true  // Pour Jest au lieu de Mocha
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "module"
    },
    "rules": {
      "indent": ["error", 2],
      "linebreak-style": ["error", "unix"],
      "quotes": ["error", "double"],
      "semi": ["error", "always"],
      "constructor-super": "off"
    }
  }
  